# Public canonical website URL. Replace this after connecting a custom domain.
NEXT_PUBLIC_SITE_URL=https://mvpready.dev

# Google Apps Script web app attached to the lead spreadsheet. The script
# persists submissions and emails the configured recipients.
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=

# Native Google Calendar booking. Share the target Google Calendar with the
# service account client email and grant "Make changes to events".
GOOGLE_CALENDAR_ID=primary-or-calendar-id@group.calendar.google.com
GOOGLE_CALENDAR_CLIENT_EMAIL=google-service-account@project-id.iam.gserviceaccount.com
GOOGLE_CALENDAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_NOTIFICATION_EMAIL=hello@mvpready.dev

# Public contact email used in mailto fallbacks and organization metadata.
NEXT_PUBLIC_CONTACT_EMAIL=hello@mvpready.dev

# Optional public social profiles used in Organization and author schemas.
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/mvpready
NEXT_PUBLIC_X_URL=
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_YOUTUBE_URL=
